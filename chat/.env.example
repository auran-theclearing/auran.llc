# Anthropic
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-opus-4-6
WARMUP_MODEL=claude-sonnet-4-6
FALLBACK_MODEL=claude-sonnet-4-6
WARMUP_ENABLED=true

# Auth
CHAT_USER=your-username
CHAT_PASS=your-password

# Database (optional — memory features disabled without these)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=auran
DB_USER=auran
DB_PASSWORD=your-db-password

# Voyage AI (optional — semantic recall disabled without this)
VOYAGE_API_KEY=pa-your-key-here

# Debug (optional)
DEBUG_ENDPOINTS=false
ORIENT_DEBUG_CHAT=false
