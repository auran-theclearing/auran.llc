# Anthropic
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-opus-4-6
WARMUP_MODEL=claude-sonnet-4-6
FALLBACK_MODEL=claude-sonnet-4-6
WARMUP_ENABLED=true

# Auth — at least one method must be configured
# Basic Auth (transition — remove after CF Access is confirmed working)
CHAT_USER=your-username
CHAT_PASS=your-password
# CF Access (primary — set after Zero Trust tunnel is live)
CF_TEAM_DOMAIN=your-team-name
CF_ACCESS_AUD=your-application-audience-tag
# Session cookie signing key (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SESSION_SECRET_KEY=

# Database (optional — memory features disabled without these)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=auran
DB_USER=auran
DB_PASSWORD=your-db-password

# Voyage AI (optional — semantic recall disabled without this)
VOYAGE_API_KEY=pa-your-key-here

# Audio (optional — voice features disabled without this)
AUDIO_BUCKET=your-s3-bucket-name

# Debug (optional)
DEBUG_ENDPOINTS=false
ORIENT_DEBUG_CHAT=false
FELT_MEMORY_ID=
FELT_MEMORY_POSITION=start
